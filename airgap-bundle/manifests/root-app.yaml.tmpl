# Rendered by install.sh (envsubst) into the root "father" Application, pointed at
# whichever git backend config.env selects. See ../../argocd/root-app.yaml for the
# GitHub-source version used by the normal (non-air-gapped) bootstrap path.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: camel-routes-root
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: ${REPO_URL}
    targetRevision: ${REVISION}
    path: argocd
  destination:
    server: https://kubernetes.default.svc
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - ServerSideApply=true
