# Air-gap bootstrap config for camel-routes-gitops.
# Copy to config.env (same directory as install.sh) and edit before running install.sh.

# gitea:    deploy an in-cluster Gitea, seed it with this bundle's repo-snapshot/, and
#           point Argo CD at it. Fully offline, no external git server needed. Default.
# external: skip Gitea entirely; point Argo CD at REPO_URL, a git server you already run
#           (your own GitLab/Gitea/etc). You are responsible for that repo's content
#           (chart/, routes/, argocd/) already being correct and reachable from the cluster.
GIT_BACKEND=gitea

# Branch/tag Argo CD tracks.
REVISION=main

### GIT_BACKEND=gitea settings (ignored when GIT_BACKEND=external)
GITEA_ADMIN_USER=gitops
GITEA_ADMIN_PASSWORD=change-me-before-running
GITEA_REPO_OWNER=gitops
GITEA_REPO_NAME=camel-routes-gitops
GITEA_NODEPORT=30501

### GIT_BACKEND=external settings (required when GIT_BACKEND=external)
#REPO_URL=https://git.internal.example.com/camel-routes-gitops.git
